---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  breadcrumb?: { label: string; href: string }[];
}

const {
  title = "FIDESZ SAPKA",
  description = "archive",
  breadcrumb = [],
} = Astro.props;
---

<html lang="hu">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f3efe7" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var s = localStorage.getItem("fs-theme");
        var d = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (s === "dark" || (!s && d)) document.documentElement.dataset.theme = "dark";
      })();
    </script>
  </head>
  <body>
    <header class="drive-toolbar">
      <a href="/" class="drive-toolbar__logo" aria-label="Home">
        <span class="drive-toolbar__mark" aria-hidden="true">
          <img
            src="/brand/drive-logo-source.jpeg"
            alt=""
            class="drive-toolbar__mark-layer drive-toolbar__mark-layer--base"
          />
          <img
            src="/brand/drive-logo-source.jpeg"
            alt=""
            class="drive-toolbar__mark-layer drive-toolbar__mark-layer--red"
          />
          <img
            src="/brand/drive-logo-source.jpeg"
            alt=""
            class="drive-toolbar__mark-layer drive-toolbar__mark-layer--blue"
          />
        </span>
        <span class="drive-toolbar__titleblock">
          <span class="glitch-text" data-text="FIDESZ SAPKA">FIDESZ SAPKA</span>
        </span>
      </a>
      <div class="drive-toolbar__meta mono" aria-label="Archive metadata">
        <span>updated 2026-04-20</span>
        <button id="theme-toggle" aria-label="Toggle dark mode">dark</button>
      </div>
    </header>

    <div class="archive-shell">
      <nav class="drive-breadcrumb" aria-label="Breadcrumb">
        <a href="/">FIDESZ SAPKA</a>
        {breadcrumb.map((crumb) => (
          <>
            <span class="drive-breadcrumb__sep">›</span>
            {crumb.href ? (
              <a href={crumb.href}>{crumb.label}</a>
            ) : (
              <span class="drive-breadcrumb__current">{crumb.label}</span>
            )}
          </>
        ))}
      </nav>

      <main class="archive-main">
        <slot />
      </main>

      <footer class="drive-footer">
        <p style="margin:0">fidesz sapka · ig: <a href="https://instagram.com/fideszsapka">@fideszsapka</a></p>
      </footer>
    </div>

    <canvas class="glitch-noise" aria-hidden="true"></canvas>
    <div class="glitch-vignette" aria-hidden="true"></div>
  </body>
</html>

<script is:inline>
  (() => {
    const root = document.body;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (reduced) return;

    // Animated canvas grain — 256×256 pixelated, ~20fps
    const canvas = document.querySelector("canvas.glitch-noise");
    if (canvas && canvas.getContext) {
      const ctx = canvas.getContext("2d");
      const SIZE = 256;
      canvas.width = SIZE;
      canvas.height = SIZE;
      const buf = new Uint8ClampedArray(SIZE * SIZE * 4);
      let frame = 0;

      const drawGrain = () => {
        frame++;
        if (frame % 3 === 0) {
          for (let i = 0; i < buf.length; i += 4) {
            const v = (Math.random() * 256) | 0;
            buf[i] = buf[i + 1] = buf[i + 2] = v;
            buf[i + 3] = 255;
          }
          ctx.putImageData(new ImageData(buf, SIZE, SIZE), 0, 0);
        }
        requestAnimationFrame(drawGrain);
      };
      drawGrain();
    }

    const rnd = (a, b) => a + Math.random() * (b - a);

    // Theme toggle
    const toggleBtn = document.getElementById("theme-toggle");
    if (toggleBtn) {
      const sync = () => {
        const dark = document.documentElement.dataset.theme === "dark";
        toggleBtn.textContent = dark ? "light" : "dark";
      };
      sync();
      toggleBtn.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("fs-theme", next);
        sync();
      });
    }

    // Micro-flicker — rare, brief luminance flash like a tube warming up
    const flickEl = document.createElement("div");
    flickEl.style.cssText = "position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:0;background:rgba(248,244,235,0.12);";
    document.body.appendChild(flickEl);

    const flicker = () => {
      flickEl.style.opacity = (0.06 + Math.random() * 0.09).toFixed(3);
      setTimeout(() => {
        flickEl.style.opacity = "0";
        if (Math.random() < 0.38) {
          setTimeout(() => {
            flickEl.style.opacity = (0.04 + Math.random() * 0.06).toFixed(3);
            setTimeout(() => { flickEl.style.opacity = "0"; }, 16 + rnd(0, 32));
          }, rnd(40, 110));
        }
      }, 16 + rnd(0, 50));
      setTimeout(flicker, rnd(7000, 22000));
    };
    setTimeout(flicker, rnd(4000, 10000));
  })();
</script>
