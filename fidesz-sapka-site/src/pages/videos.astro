---
import Base from "../layouts/Base.astro";
import { videos } from "../data/videos";
---

<Base
  title="FIDESZ SAPKA — videos"
  description="archive / videos"
  breadcrumb={[{ label: "videos", href: "" }]}
>
  <div class="drive-grid drive-grid--video">
    {videos.map((v, i) => {
      const name = v.file.split("/").pop();
      return (
        <figure class="drive-grid__item drive-grid__item--video" data-video-idx={String(i)}>
          <div class="drive-grid__video-thumb">
            {v.poster
              ? <img src={v.poster} alt="" loading="lazy" />
              : <div class="drive-grid__video-noposter" />
            }
            <span class="drive-grid__play-btn" aria-hidden="true">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 5v14l11-7z" fill="white"/>
              </svg>
            </span>
          </div>
          <div class="drive-grid__video-embed">
            <button class="drive-grid__video-close" aria-label="Close">×</button>
            <video controls playsinline preload="metadata" poster={v.poster}>
              <source src={v.file} type="video/mp4" />
            </video>
          </div>
          <figcaption>{name}</figcaption>
        </figure>
      );
    })}
  </div>
</Base>

<script>
  document.querySelectorAll<HTMLElement>(".drive-grid__item--video").forEach((item) => {
    const thumb = item.querySelector<HTMLElement>(".drive-grid__video-thumb");
    const closeBtn = item.querySelector<HTMLElement>(".drive-grid__video-close");

    const close = () => {
      item.classList.remove("is-playing");
      item.querySelector<HTMLVideoElement>("video")?.pause();
    };

    thumb?.addEventListener("click", () => {
      const wasPlaying = item.classList.contains("is-playing");
      document.querySelectorAll<HTMLElement>(".drive-grid__item--video.is-playing").forEach((el) => {
        el.classList.remove("is-playing");
        el.querySelector<HTMLVideoElement>("video")?.pause();
      });
      if (!wasPlaying) {
        item.classList.add("is-playing");
        item.querySelector<HTMLVideoElement>("video")?.play().catch(() => {});
      }
    });

    closeBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      close();
    });
  });
</script>
