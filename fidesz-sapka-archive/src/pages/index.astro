---
import '../styles/global.css';
import AudioPlayer from '../components/AudioPlayer.astro';
import catalog from '../data/catalog.json';

const now = new Date().toISOString().slice(0, 10);
---

<html lang="hu">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="FIDESZ SAPKA — FS-ARCHIVE. Catalog terminal." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <title>FS-ARCHIVE</title>
  </head>
  <body>
    <!-- ═══════════════ BOOT SEQUENCE ═══════════════ -->
    <header class="header" id="header">
      <pre class="boot-text">
╔══════════════════════════════════════════════════════╗
║  FS-ARCHIVE v0.1.0                                  ║
║  FIDESZ SAPKA — CATALOG TERMINAL                    ║
║  INITIALIZED: {now}                            ║
╚══════════════════════════════════════════════════════╝</pre>
      <div class="prompt">
        <span class="prompt-user">visitor@fs-archive</span>:<span class="prompt-path">~/catalog</span>$ <span class="prompt-cmd">ls -la --sort=date</span>
      </div>
    </header>

    <!-- ═══════════════ CATALOG TABLE ═══════════════ -->
    <main>
      <section class="section" id="catalog">
        <div class="section-header">
          <span>drwxr-xr-x  {catalog.length} items  ./catalog/</span>
        </div>
        <div class="table-wrapper">
          <table class="catalog-table" id="catalog-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>FILENAME</th>
                <th>TYPE</th>
                <th>DATE</th>
                <th>STATUS</th>
                <th>PLAY</th>
              </tr>
            </thead>
            <tbody>
              {catalog.map((track) => (
                <tr class={track.status === 'PENDING_RELEASE' ? 'row-pending' : 'row-released'}>
                  <td class="col-id">{track.id}</td>
                  <td class="col-filename">{track.filename}</td>
                  <td class="col-type">{track.type}</td>
                  <td class="col-date">{track.date}</td>
                  <td class="col-status">
                    <span class={track.status === 'RELEASED' ? 'status-released' : 'status-pending'}>
                      {track.status}
                    </span>
                  </td>
                  <td class="col-play">
                    <AudioPlayer src={track.audio} trackId={track.id} title={track.title} />
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- ═══════════════ STREAM LINKS ═══════════════ -->
      <section class="section" id="stream-links">
        <div class="prompt">
          <span class="prompt-user">visitor@fs-archive</span>:<span class="prompt-path">~/external</span>$ <span class="prompt-cmd">cat links.txt</span>
        </div>
        <div class="links-output">
          <p>> <a href="https://open.spotify.com/artist/FIDESZ_SAPKA" target="_blank" rel="noopener">SPOTIFY</a></p>
          <p>> <a href="https://music.apple.com/artist/FIDESZ_SAPKA" target="_blank" rel="noopener">APPLE_MUSIC</a></p>
          <p>> <a href="https://www.instagram.com/fideszsapka/" target="_blank" rel="noopener">INSTAGRAM</a></p>
          <p>> <a href="https://www.tiktok.com/@fideszsapka" target="_blank" rel="noopener">TIKTOK</a></p>
        </div>
      </section>

      <!-- ═══════════════ EVIDENCE BOARD ═══════════════ -->
      <section class="section" id="evidence">
        <div class="prompt">
          <span class="prompt-user">visitor@fs-archive</span>:<span class="prompt-path">~/evidence</span>$ <span class="prompt-cmd">find . -type f -name "*.jpg" | head -6</span>
        </div>
        <div class="evidence-grid" id="evidence-grid">
          <div class="evidence-item">
            <div class="evidence-placeholder">
              <span>./evidence/001_studio_session.jpg</span>
              <span class="evidence-meta">[ DROP IMAGE HERE ]</span>
            </div>
          </div>
          <div class="evidence-item">
            <div class="evidence-placeholder">
              <span>./evidence/002_greenscreen_shoot.jpg</span>
              <span class="evidence-meta">[ DROP IMAGE HERE ]</span>
            </div>
          </div>
          <div class="evidence-item">
            <div class="evidence-placeholder">
              <span>./evidence/003_vhs_capture.jpg</span>
              <span class="evidence-meta">[ DROP IMAGE HERE ]</span>
            </div>
          </div>
          <div class="evidence-item">
            <div class="evidence-placeholder">
              <span>./evidence/004_ms_paint_catalog.jpg</span>
              <span class="evidence-meta">[ DROP IMAGE HERE ]</span>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- ═══════════════ FOOTER ═══════════════ -->
    <footer class="footer" id="footer">
      <hr class="divider" />
      <pre class="footer-text">
LAST_MODIFIED: {now}
TOTAL_ASSETS: {catalog.length}
ARCHIVE_STATUS: ACTIVE
--- END_OF_FILE ---</pre>
    </footer>

    <!-- ═══════════════ AUDIO ENGINE ═══════════════ -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        let currentAudio: HTMLAudioElement | null = null;
        let currentBtn: HTMLButtonElement | null = null;
        let animFrame: number | null = null;

        function formatTime(s: number): string {
          const m = Math.floor(s / 60);
          const sec = Math.floor(s % 60);
          return `${String(m).padStart(2, '0')}:${String(sec).padStart(2, '0')}`;
        }

        function stopCurrent() {
          if (currentAudio) {
            currentAudio.pause();
            currentAudio.currentTime = 0;
          }
          if (currentBtn) {
            currentBtn.textContent = '[ ▶ ]';
            currentBtn.classList.remove('playing');
          }
          if (animFrame) cancelAnimationFrame(animFrame);
          animFrame = null;
        }

        function updateProgress(trackId: string) {
          const audio = document.getElementById(`audio-${trackId}`) as HTMLAudioElement;
          const bar = document.getElementById(`bar-${trackId}`) as HTMLElement;
          const time = document.getElementById(`time-${trackId}`) as HTMLElement;
          if (!audio || !bar || !time) return;

          const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
          bar.style.width = `${pct}%`;
          time.textContent = formatTime(audio.currentTime);

          if (!audio.paused) {
            animFrame = requestAnimationFrame(() => updateProgress(trackId));
          }
        }

        document.querySelectorAll('.play-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            const button = btn as HTMLButtonElement;
            const trackId = button.dataset.trackId!;
            const audioSrc = button.dataset.audioSrc!;
            const audio = document.getElementById(`audio-${trackId}`) as HTMLAudioElement;

            if (currentAudio === audio && !audio.paused) {
              stopCurrent();
              return;
            }

            stopCurrent();

            currentAudio = audio;
            currentBtn = button;
            audio.play();
            button.textContent = '[ ■ ]';
            button.classList.add('playing');
            updateProgress(trackId);

            audio.addEventListener('ended', () => {
              stopCurrent();
              const bar = document.getElementById(`bar-${trackId}`) as HTMLElement;
              const time = document.getElementById(`time-${trackId}`) as HTMLElement;
              if (bar) bar.style.width = '0%';
              if (time) time.textContent = '00:00';
            }, { once: true });
          });
        });

        // Click-to-seek on progress bars
        document.querySelectorAll('.progress-container').forEach((container) => {
          container.addEventListener('click', (e) => {
            const el = container as HTMLElement;
            const trackId = el.id.replace('progress-', '');
            const audio = document.getElementById(`audio-${trackId}`) as HTMLAudioElement;
            if (!audio || !audio.duration) return;
            const rect = el.getBoundingClientRect();
            const x = (e as MouseEvent).clientX - rect.left;
            const pct = x / rect.width;
            audio.currentTime = pct * audio.duration;
          });
        });
      });
    </script>
  </body>
</html>

<style>
  /* ── HEADER ─────────────────────────────── */
  .header {
    margin-bottom: 2rem;
  }

  .boot-text {
    color: var(--color-terminal-green-dim);
    font-size: 12px;
    line-height: 1.4;
    margin-bottom: 1rem;
    white-space: pre;
    overflow-x: auto;
  }

  .prompt {
    font-size: 13px;
    margin-bottom: 0.75rem;
    white-space: nowrap;
    overflow-x: auto;
  }

  .prompt-user {
    color: var(--color-terminal-purple);
  }

  .prompt-path {
    color: var(--color-terminal-green);
  }

  .prompt-cmd {
    color: var(--color-terminal-white);
  }

  /* ── SECTIONS ───────────────────────────── */
  .section {
    margin-bottom: 2.5rem;
  }

  .section-header {
    color: var(--color-terminal-gray-light);
    font-size: 12px;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-terminal-gray);
    margin-bottom: 0.5rem;
  }

  /* ── CATALOG TABLE ──────────────────────── */
  .table-wrapper {
    overflow-x: auto;
  }

  .catalog-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }

  .catalog-table th {
    text-align: left;
    color: var(--color-terminal-gray-light);
    border-bottom: 1px solid var(--color-terminal-gray);
    padding: 6px 8px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .catalog-table td {
    padding: 8px;
    border-bottom: 1px solid var(--color-terminal-gray);
    vertical-align: middle;
  }

  .catalog-table tr:hover {
    background: rgba(0, 255, 65, 0.04);
  }

  .col-id {
    color: var(--color-terminal-purple);
    font-weight: 700;
    white-space: nowrap;
  }

  .col-filename {
    color: var(--color-terminal-white);
  }

  .col-type,
  .col-date {
    color: var(--color-terminal-gray-light);
    white-space: nowrap;
  }

  .status-released {
    color: var(--color-terminal-green);
  }

  .status-pending {
    color: var(--color-terminal-red);
    animation: blink 1.2s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .row-pending {
    opacity: 0.6;
  }

  .row-pending:hover {
    opacity: 1;
  }

  /* ── STREAM LINKS ───────────────────────── */
  .links-output {
    padding-left: 0.5rem;
  }

  .links-output p {
    margin-bottom: 0.25rem;
    font-size: 13px;
  }

  /* ── EVIDENCE BOARD ─────────────────────── */
  .evidence-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1px;
    background: var(--color-terminal-gray);
    border: 1px solid var(--color-terminal-gray);
    margin-top: 0.5rem;
  }

  .evidence-item {
    background: var(--color-terminal-black);
    aspect-ratio: 1;
    overflow: hidden;
  }

  .evidence-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(40%) contrast(1.2);
    transition: none;
  }

  .evidence-item:hover img {
    filter: grayscale(0%) contrast(1);
  }

  .evidence-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1rem;
    color: var(--color-terminal-gray-light);
    font-size: 11px;
    border: 1px dashed var(--color-terminal-gray-light);
  }

  .evidence-meta {
    margin-top: 0.5rem;
    color: var(--color-terminal-gray);
    font-size: 10px;
  }

  /* ── FOOTER ─────────────────────────────── */
  .footer {
    margin-top: 3rem;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--color-terminal-gray);
    margin-bottom: 1rem;
  }

  .footer-text {
    color: var(--color-terminal-gray-light);
    font-size: 11px;
    line-height: 1.5;
  }

  /* ── RESPONSIVE ─────────────────────────── */
  @media (max-width: 600px) {
    html {
      font-size: 12px;
    }

    .boot-text {
      font-size: 10px;
    }

    .evidence-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
